# ─── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string (Neon/Supabase/local)
DATABASE_URL=postgresql://user:password@host:5432/polezno_irkutsk

# ─── Payload CMS ──────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-key-minimum-32-chars

# ─── Next.js ──────────────────────────────────────────────────────
# Локально: http://localhost:3000 | Production (Beget): https://irkportal.ru
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_BOOSTY_URL=https://boosty.to/polezno_irkutsk
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/poleznoproirkutsk

# ─── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Яндекс Карты (JS API 3.0) ────────────────────────────────────
# Ключ: https://developer.tech.yandex.ru/ — ограничьте доменом irkportal.ru
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
# Серверный ключ маршрутизации (опционально; иначе используется NEXT_PUBLIC_YANDEX_MAPS_API_KEY)
YANDEX_ROUTER_API_KEY=
# Яндекс.Метрика (счётчик на всех публичных страницах)
NEXT_PUBLIC_YANDEX_METRIKA_ID=109995467

# ─── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@polezno.irkutsk.ru
EMAIL_TO=info@polezno.irkutsk.ru

# ─── Revalidation ──────────────────────────────────────────────────
REVALIDATE_SECRET=your-revalidate-secret

# First admin (npm run create-admin)
ADMIN_SEED_EMAIL=admin@polezno-irkutsk.local
ADMIN_SEED_PASSWORD=
