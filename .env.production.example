# Production на VPS (Beget, Ubuntu 24.04, irkportal.ru)
# Скопируйте на сервер: cp .env.production.example .env.production
# Для npm run create-admin / seed: ln -sf .env.production .env.local
# В git не коммитить реальные секреты.

# ─── Database (локальный PostgreSQL на VPS) ───────────────────────
# Neon / Supabase не используются
DATABASE_URL=postgresql://polezno_irkutsk:ЗАМЕНИТЕ_ПАРОЛЬ@localhost:5432/polezno_irkutsk

# ─── Payload CMS ──────────────────────────────────────────────────
PAYLOAD_SECRET=минимум-32-случайных-символа-сгенерируйте-локально

# ─── Next.js ──────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=https://irkportal.ru
NEXT_PUBLIC_BOOSTY_URL=https://boosty.to/polezno_irkutsk

# ─── Revalidation (обязательно для CMS → кэш страниц) ─────────────
REVALIDATE_SECRET=случайная-строка-24-32-символа

# ─── Next.js Server Actions (обязательно для /admin Payload) ───────
# Сгенерируйте: openssl rand -base64 32
# После добавления — обязательно npm run build && pm2 restart polezno
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ─── Первый админ (npm run create-admin) ──────────────────────────
ADMIN_SEED_EMAIL=admin@irkportal.ru
ADMIN_SEED_PASSWORD=

# ─── Опционально (позже) ──────────────────────────────────────────
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=ключ-из-developer.tech.yandex.ru
# RESEND_API_KEY=
# EMAIL_FROM=noreply@irkportal.ru
# EMAIL_TO=info@irkportal.ru
